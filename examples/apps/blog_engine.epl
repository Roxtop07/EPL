Note: ─── API — List Posts as JSON ────────────────────────

Route "/api/posts" responds with
    posts = load_posts()
    Send json Map with blog = BLOG_TITLE and posts = posts and count = length(posts)
End

Note: ─── About Page ──────────────────────────────────────

Route "/about" shows
    Page "About — " + BLOG_TITLE
        Heading "About This Blog"
        Text "This blog engine is built entirely in EPL (English Programming Language)."
        Text "It reads Markdown files from a 'posts' directory and serves them as web pages."
        SubHeading "How It Works"
        List ["Markdown files stored in /posts directory", "EPL reads files on each request", "Content served with EPL web framework", "JSON API available at /api/posts"]
        Link "Back to Home" to "/"
    End
End

Note: ─── Initialize and Start ────────────────────────────

setup_blog()
Say "═══════════════════════════════════════════"
Say "  " + BLOG_TITLE
Say "  " + BLOG_TAGLINE
Say "  Posts directory: " + POSTS_DIR
Say "  Open: http://localhost:3000"
Say "═══════════════════════════════════════════"
Start blogApp on port 3000
