Note: EPL Discord Bot
Note: A fun bot that demonstrates EPL's capabilities
Note: Prerequisites: pip install discord.py
Note: DISCORD_BOT_TOKEN = env var before running
Note: Run: epl run examples/apps/discord_bot.epl
Note: ═══════════════════════════════════════════════════════

Use python "discord"

Note: ─── Bot Configuration ────────────────────────────────
TOKEN = env("DISCORD_BOT_TOKEN")
PREFIX = "!"
VERSION = "1.0.0"

Note: ─── Command Responses ───────────────────────────────

help_text = "**EPL Bot Commands:**\n"
help_text = help_text + "`!hello` — Greet you\n"
help_text = help_text + "`!about` — About EPL\n"
help_text = help_text + "`!syntax` — Say EPL vs Python syntax\n"
help_text = help_text + "`!example` — Random EPL code example\n"
help_text = help_text + "`!quote` — Programming quote\n"
help_text = help_text + "`!stats` — Bot statistics\n"
help_text = help_text + "`!help` — This message"

syntax_comparison = "**EPL vs Python:**\n"
syntax_comparison = syntax_comparison + "```\n"
syntax_comparison = syntax_comparison + "Python:  print('Hello')         EPL:  Say 'Hello'\n"
syntax_comparison = syntax_comparison + "Python:  x = 10                 EPL:  x = 10\n"
syntax_comparison = syntax_comparison + "Python:  if x > 5:              EPL:  If x Is Greater Than 5 Then\n"
syntax_comparison = syntax_comparison + "Python:  for i in range(10):    EPL:  Repeat 10 Times\n"
syntax_comparison = syntax_comparison + "Python:  def greet():           EPL:  Function greet\n"
syntax_comparison = syntax_comparison + "```"

about_text = "**EPL — English Programming Language** 🚀\n\n"
about_text = about_text + "EPL is a programming language where code reads like plain English.\n"
about_text = about_text + "It compiles to native executables via LLVM, transpiles to JavaScript/Kotlin,\n"
about_text = about_text + "and has a 725-function standard library.\n\n"
about_text = about_text + "🔗 **Install:** `pip install epl-lang`\n"
about_text = about_text + "📖 **GitHub:** github.com/epl-lang/epl"

examples = ["Say 'Hello, World!'", "age = 25\nIf age Is Greater Than 18 Then\n    Say 'You are an adult'\nEnd", "fruits = ['apple', 'banana', 'cherry']\nFor Each fruit In fruits\n    Say fruit\nEnd", "Function factorial takes n\n    If n Is Less Than 2 Then\n        Return 1\n    End\n    Return n * factorial(n - 1)\nEnd\nSay factorial(5)", "Repeat 5 Times\n    Say 'EPL is awesome!'\nEnd"]

quotes = ["'Programs must be written for people to read, and only incidentally for machines to execute.' — Harold Abelson", "'Any fool can write code that a computer can understand. Good programmers write code that humans can understand.' — Martin Fowler", "'The best way to predict the future is to invent it.' — Alan Kay", "'Talk is cheap. Say me the code.' — Linus Torvalds", "'In EPL, the code IS the explanation.' — EPL Team"]

